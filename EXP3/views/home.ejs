<%- include('partials/head')%>
</head>
<body class="bg-gray-100 min-h-screen">

<%- include('partials/nav')%>

<main class="flex justify-center mt-16 px-4">
  <div class="w-full max-w-2xl bg-white/95 backdrop-blur-sm shadow-xl rounded-2xl border border-gray-100 px-8 sm:px-12 py-8">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-800 tracking-tight mb-6">
      Here are our registered homes
    </h1>

    <ul class="space-y-3">
      <% registerHome.forEach(home => { %>
        <li class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-gray-700 font-medium hover:bg-red-50 hover:border-red-200 transition">
          <%= home.homeName %>
        </li>
      <% }) %>
    </ul>
  </div>
</main>

</body>
</html>